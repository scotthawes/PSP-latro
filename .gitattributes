# Use Git LFS for large binary assets (requires Git LFS enabled locally)
assets/out/*.ogg filter=lfs diff=lfs merge=lfs -text
assets/out/*.wav filter=lfs diff=lfs merge=lfs -text
assets/out/*.mp3 filter=lfs diff=lfs merge=lfs -text
assets/out/*.png filter=lfs diff=lfs merge=lfs -text
assets/out/*.dds filter=lfs diff=lfs merge=lfs -text
build/EBOOT.PBP filter=lfs diff=lfs merge=lfs -text
*.pbp filter=lfs diff=lfs merge=lfs -text
*.iso filter=lfs diff=lfs merge=lfs -text

# Ensure text normalization for scripts
*.sh text eol=lf
